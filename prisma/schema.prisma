generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model Pilot {
  id          String   @id @default(cuid())
  name        String
  phone       String   @unique
  email       String?
  city        String   @default("Hyderabad")
  dgcaId      String?
  services    String   @default("[]")
  rating      Float    @default(5.0)
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
}

model Booking {
  id           String   @id @default(cuid())
  customerName String
  phone        String
  service      String
  location     String
  date         String
  status       String   @default("pending")
  pilotId      String?
  createdAt    DateTime @default(now())
}

model GallerySubmission {
  id        String   @id @default(cuid())
  pilotName String
  badge     String
  title     String
  location  String
  imageUrl  String
  videoId   String?
  status    String   @default("pending")
  createdAt DateTime @default(now())
}

model PilotApplication {
  id          String   @id @default(cuid())
  name        String
  whatsapp    String   @unique
  areas       String
  dgcaId      String
  experience  String?
  droneModels String
  shootTypes  String?
  notes       String?
  status      String   @default("pending")
  createdAt   DateTime @default(now())
}

